{
  "name": "coolnamehere-design-system",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "npm run build:web",
    "build:web": "npm run storybook-generate && EXPO_PUBLIC_STORYBOOK_ENABLED=true expo export --platform web && node ./scripts/postprocess-web-metadata.mjs",
    "typecheck": "tsc --noEmit",
    "storybook-generate": "sb-rn-get-stories",
    "storybook": "npm run storybook-generate && expo start -c"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@storybook/addon-ondevice-actions": "^10.2.3",
    "@storybook/addon-ondevice-backgrounds": "^10.2.3",
    "@storybook/addon-ondevice-controls": "^10.2.3",
    "@storybook/addon-ondevice-notes": "^10.2.3",
    "@storybook/react-native": "^10.2.3",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "storybook": "^10.2.13"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "storybook-dark-mode": "^4.0.2",
    "typescript": "~5.9.2"
  }
}
